generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // CANDIDATE, RECRUITER, ADMIN
  users User[]

  @@map("roles")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  fullName    String   @map("full_name")
  avatar      String?
  roleId      Int      @map("role_id")
  role        Role     @relation(fields: [roleId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  cvs          CV[]
  company      Company? @relation("RecruiterCompany")
  jobs         Job[]    @relation("PostedBy")
  applications Application[]
  sentMsgs     Message[] @relation("Sender")
  receivedMsgs Message[] @relation("Receiver")

  @@map("users")
}

model CV {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  title     String
  template  String   // Template name
  data      Json     // Education, experience, etc. in JSON
  pdfUrl    String?  @map("pdf_url") // Cloudinary URL
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applications Application[]

  @@map("cvs")
}

model Company {
  id          String @id @default(uuid())
  name        String
  description String?
  logoUrl     String? @map("logo_url")
  recruiterId String @unique @map("recruiter_id")
  recruiter   User   @relation("RecruiterCompany", fields: [recruiterId], references: [id])
  
  jobs        Job[]

  @@map("companies")
}

model Job {
  id           String   @id @default(uuid())
  title        String
  description  String
  requirements Json     // Job requirements in JSON
  salary       String?
  location     String
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id])
  postedBy     String   @map("posted_by")
  author       User     @relation("PostedBy", fields: [postedBy], references: [id])
  
  // New feature: Require CV toggle
  requireCV    Boolean  @default(true) @map("require_cv")
  
  status       String   @default("OPEN") // OPEN, CLOSED
  deadline     DateTime?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  applications Application[]

  @@map("jobs")
}

model Application {
  id           String   @id @default(uuid())
  jobId        String   @map("job_id")
  job          Job      @relation(fields: [jobId], references: [id])
  candidateId  String   @map("candidate_id")
  candidate    User     @relation(fields: [candidateId], references: [id])
  
  // Optional if job.requireCV = false
  cvId         String?  @map("cv_id")
  cv           CV?      @relation(fields: [cvId], references: [id])
  
  status       String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  coverLetter  String?  @map("cover_letter")
  appliedDate  DateTime @default(now()) @map("applied_date")
  
  messages     Message[]

  @@map("applications")
}

model Message {
  id            String      @id @default(uuid())
  senderId      String      @map("sender_id")
  sender        User        @relation("Sender", fields: [senderId], references: [id])
  receiverId    String      @map("receiver_id")
  receiver      User        @relation("Receiver", fields: [receiverId], references: [id])
  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id])
  content       String
  isRead        Boolean     @default(false) @map("is_read")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("messages")
}
